# PAXA — API Credentials
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# TikTok Marketing API
# Get from: TikTok Ads Manager → Tools → Developer → My Apps → your app → Access Token
TIKTOK_ACCESS_TOKEN=paste_your_access_token_here

# Get from: TikTok Ads Manager → top-left dropdown → your account number
TIKTOK_ADVERTISER_ID=paste_your_advertiser_id_here

# Get from: TikTok Ads Manager → Tools → Developer → My Apps → App ID
TIKTOK_APP_ID=paste_your_app_id_here

# Shopify Admin API
# Get from: Shopify Admin → Settings → Apps and sales channels → Develop apps
# → Create app → Admin API scopes: write_shipping, read_shipping → Install → copy token
SHOPIFY_ACCESS_TOKEN=paste_your_shopify_admin_token_here

# Your Shopify store domain (the .myshopify.com address)
SHOPIFY_SHOP_DOMAIN=ph6pk1-fq.myshopify.com
