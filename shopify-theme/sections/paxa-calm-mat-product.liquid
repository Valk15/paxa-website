    'https://cdn.shopify.com/s/files/1/1037/8874/0945/files/O1CN01cUieph1GIqRg7a6nz__2817070600-0-cib.jpg?v=1776245217',
    'https://cdn.shopify.com/s/files/1/1037/8874/0945/files/5976563626975890676_121.jpg?v=1776245217',
    'https://cdn.shopify.com/s/files/1/1037/8874/0945/files/5976563626975890675_121.jpg?v=1776245217'
  ];

  var currentIdx = 0;
  var mainImg    = document.getElementById('pcm-main-img');
  var thumbBtns  = document.querySelectorAll('.pcm-thumb');
  var M = (typeof Motion !== 'undefined') ? Motion : null;

  /* ── 1. MOTION SCROLL REVEALS ── */
  if (M && M.inView) {
    M.inView('.pcm-reveal', function (info) {
      M.animate(info.target, { opacity: [0, 1], y: [30, 0] }, {
        duration: 0.6,
        easing: [0.16, 1, 0.3, 1]
      });
    });
  }

  /* ── 2. REVIEW CARDS STAGGER ── */
  if (M && M.inView) {
    M.inView('#pcm-reviews-grid', function (info) {
      var cards = info.target.querySelectorAll('.pcm-review-card');
      M.animate(cards, { opacity: [0, 1], y: [20, 0] }, {
        delay: M.stagger ? M.stagger(0.08) : 0,
        duration: 0.5
      });
    });
  }

  /* ── 3. BUY BUTTON HOVER ── */
  if (M && M.animate) {
    document.querySelectorAll('.pcm-buy-btn, .pcm-cta-btn').forEach(function (btn) {
      btn.addEventListener('mouseenter', function () {
        M.animate(btn, { scale: 1.02 }, { duration: 0.15 });
      });
      btn.addEventListener('mouseleave', function () {
        M.animate(btn, { scale: 1 }, { duration: 0.15 });
      });
    });
  }

  /* ── GALLERY ── */
  function setImage(idx, src) {
    currentIdx = idx;
    if (!mainImg) return;

    if (M && M.animate) {
      M.animate(mainImg, { opacity: [1, 0] }, { duration: 0.15 });
      setTimeout(function () {
        mainImg.src = src;
        M.animate(mainImg, { opacity: [0, 1] }, { duration: 0.2 });
      }, 150);
    } else {
      mainImg.src = src;
    }

    thumbBtns.forEach(function (t) {
      var active = parseInt(t.dataset.index, 10) === idx;
      t.classList.toggle('active', active);
      t.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
  }

  thumbBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      setImage(parseInt(btn.dataset.index, 10), IMAGES[parseInt(btn.dataset.index, 10)]);
    });
  });

  var prevBtn = document.getElementById('pcm-prev');
  var nextBtn = document.getElementById('pcm-next');
  if (prevBtn) prevBtn.addEventListener('click', function () {
    var i = (currentIdx - 1 + IMAGES.length) % IMAGES.length;
    setImage(i, IMAGES[i]);
  });
  if (nextBtn) nextBtn.addEventListener('click', function () {
    var i = (currentIdx + 1) % IMAGES.length;
    setImage(i, IMAGES[i]);
  });

  /* Touch swipe */
  var swipeX = 0;
  if (mainImg) {
    mainImg.addEventListener('touchstart', function (e) { swipeX = e.changedTouches[0].clientX; }, { passive: true });
    mainImg.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - swipeX;
      if (Math.abs(dx) > 44) {
        var i = dx < 0
          ? (currentIdx + 1) % IMAGES.length
          : (currentIdx - 1 + IMAGES.length) % IMAGES.length;
        setImage(i, IMAGES[i]);
      }
    }, { passive: true });
  }

  /* ── VARIANT SELECTOR ── */
  var variantCards  = document.querySelectorAll('.pcm-variant-card');
  var variantInput  = document.getElementById('pcm-variant-id');
  var ctaInput      = document.getElementById('pcm-cta-variant-id');
  var confirmLabel  = document.getElementById('pcm-confirm-label');

  function selectVariant(card) {
    /* Deselect all */
    variantCards.forEach(function (c) {
      c.classList.remove('selected');
      c.setAttribute('aria-checked', 'false');
      c.setAttribute('tabindex', '-1');
      var chk = c.querySelector('.pcm-variant-check');
      if (chk) { chk.style.opacity = '0'; chk.style.scale = '0'; }
    });

    /* Select clicked card */
    card.classList.add('selected');
    card.setAttribute('aria-checked', 'true');
    card.setAttribute('tabindex', '0');

    /* 4. Animate checkmark spring */
    var check = card.querySelector('.pcm-variant-check');
    if (check) {
      if (M && M.animate) {
        M.animate(check, { scale: [0, 1], opacity: [0, 1] }, {
          type: 'spring',
          stiffness: 500,
          damping: 25
        });
      } else {
        check.style.opacity = '1';
        check.style.scale = '1';
      }
    }

    var vid   = card.dataset.variantId;
    var name  = card.dataset.variantName;
    var col1  = card.dataset.color1;
    var col2  = card.dataset.color2;
    var img   = card.dataset.img;

    /* Update hidden inputs */
    if (variantInput) variantInput.value = vid;
    if (ctaInput)     ctaInput.value     = vid;

    /* Update confirmation label */
    if (confirmLabel) {
      confirmLabel.textContent = 'Selected: ' + name + ' \u2014 ' + col1 + ' + ' + col2;
      if (M && M.animate) M.animate(confirmLabel, { opacity: [0, 1] }, { duration: 0.3 });
    }

    /* Swap gallery to variant image */
    if (img) setImage(0, img);

    /* Update URL */
    try {
      var url = new URL(window.location.href);
      url.searchParams.set('variant', vid);
      window.history.replaceState({}, '', url.toString());
    } catch (e) {}
  }

  /* Initialise first checkmark */
  var firstCard = document.querySelector('.pcm-variant-card.selected .pcm-variant-check');
  if (firstCard) { firstCard.style.opacity = '1'; firstCard.style.scale = '1'; }

  variantCards.forEach(function (card) {
    card.addEventListener('click', function () { selectVariant(card); });
    card.addEventListener('keydown', function (e) {
      var arr = Array.from(variantCards);
      var i   = arr.indexOf(card);
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault(); selectVariant(card);
      } else if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        e.preventDefault(); var n = arr[(i + 1) % arr.length]; selectVariant(n); n.focus();
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        e.preventDefault(); var p = arr[(i - 1 + arr.length) % arr.length]; selectVariant(p); p.focus();
      }
    });
  });

  /* ── STAT COUNTERS ── */
  document.querySelectorAll('.pcm-stat-count').forEach(function (el) {
    var target = parseInt(el.dataset.target, 10);
    var done   = false;
    var obs    = new IntersectionObserver(function (entries) {
      if (!entries[0].isIntersecting || done) return;
      done = true; obs.disconnect();
      var start = null;
      requestAnimationFrame(function tick(ts) {
        if (!start) start = ts;
        var p = Math.min((ts - start) / 1400, 1);
        el.textContent = Math.round((1 - Math.pow(1 - p, 3)) * target);
        if (p < 1) requestAnimationFrame(tick);
      });
    }, { threshold: 0.6 });
    obs.observe(el);
  });

  /* ── FAQ ACCORDION ── */
  document.querySelectorAll('.pcm-faq-q').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var open   = btn.getAttribute('aria-expanded') === 'true';
      var answer = btn.parentElement.querySelector('.pcm-faq-a');
      var icon   = btn.querySelector('.pcm-faq-icon');

      /* Close all others */
      document.querySelectorAll('.pcm-faq-q').forEach(function (other) {
        if (other === btn) return;
        other.setAttribute('aria-expanded', 'false');
        var a = other.parentElement.querySelector('.pcm-faq-a');
        var ic = other.querySelector('.pcm-faq-icon');
        if (a) a.hidden = true;
        if (ic && M && M.animate) M.animate(ic, { rotate: 0 }, { duration: 0.22 });
      });

      if (!open) {
        btn.setAttribute('aria-expanded', 'true');
        if (answer) answer.hidden = false;
        if (icon && M && M.animate) M.animate(icon, { rotate: 180 }, { duration: 0.25, easing: 'easeInOut' });
      } else {
        btn.setAttribute('aria-expanded', 'false');
        if (answer) answer.hidden = true;
        if (icon && M && M.animate) M.animate(icon, { rotate: 0 }, { duration: 0.25, easing: 'easeInOut' });
      }
    });
  });

})();
</script>

