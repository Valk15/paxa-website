<!-- ═══════════════════════════════════════════════════════════
     PAGE SCRIPTS — no external dependencies
════════════════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  /* ── GALLERY IMAGES (hardcoded PAXA CDN) ── */
  var IMAGES = [
    'https://cdn.shopify.com/s/files/1/1037/8874/0945/files/5976563626975890682_121.jpg?v=1776245217',
    'https://cdn.shopify.com/s/files/1/1037/8874/0945/files/O1CN013UjPr01GIqRaMGbzF__2817070600-0-cib.jpg?v=1776245217',
    'https://cdn.shopify.com/s/files/1/1037/8874/0945/files/O1CN01N7mONv1GIqZQuKcFq__2817070600-0-cib.jpg?v=1776245217',
    'https://cdn.shopify.com/s/files/1/1037/8874/0945/files/O1CN0186kJW31GIqRf2AWN7__2817070600-0-cib.jpg?v=1776245217',
    'https://cdn.shopify.com/s/files/1/1037/8874/0945/files/O1CN01cUieph1GIqRg7a6nz__2817070600-0-cib.jpg?v=1776245217',
    'https://cdn.shopify.com/s/files/1/1037/8874/0945/files/5976563626975890676_121.jpg?v=1776245217',
    'https://cdn.shopify.com/s/files/1/1037/8874/0945/files/5976563626975890675_121.jpg?v=1776245217'
  ];

  var currentIdx = 0;
  var mainImg    = document.getElementById('pcm-main-img');
  var thumbBtns  = document.querySelectorAll('.pcm-thumb');

  /* ── 1. SCROLL REVEALS — CSS transition triggered by class ── */
  var revealObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('pcm-revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.pcm-reveal').forEach(function (el) {
    revealObserver.observe(el);
  });

  /* ── 2. REVIEW CARDS STAGGER ── */
  var reviewsGrid = document.getElementById('pcm-reviews-grid');
  if (reviewsGrid) {
    var reviewObserver = new IntersectionObserver(function (entries) {
      if (!entries[0].isIntersecting) return;
      reviewObserver.disconnect();
      reviewsGrid.querySelectorAll('.pcm-review-card').forEach(function (card, i) {
        setTimeout(function () {
          card.classList.add('pcm-revealed');
        }, i * 80);
      });
    }, { threshold: 0.1 });
    reviewObserver.observe(reviewsGrid);
  }

  /* ── GALLERY ── */
  function setImage(idx, src) {
    currentIdx = (idx + IMAGES.length) % IMAGES.length;
    if (!mainImg) return;

    mainImg.style.opacity = '0';
    setTimeout(function () {
      mainImg.src = src || IMAGES[currentIdx];
      mainImg.style.opacity = '1';
    }, 140);

    thumbBtns.forEach(function (t) {
      var active = parseInt(t.dataset.index, 10) === currentIdx;
      t.classList.toggle('active', active);
      t.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
  }

  thumbBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      setImage(parseInt(btn.dataset.index, 10), IMAGES[parseInt(btn.dataset.index, 10)]);
    });
  });

  var prevBtn = document.getElementById('pcm-prev');
  var nextBtn = document.getElementById('pcm-next');
  if (prevBtn) prevBtn.addEventListener('click', function () { setImage(currentIdx - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function () { setImage(currentIdx + 1); });

  /* Touch swipe */
  var swipeX = 0;
  if (mainImg) {
    mainImg.style.transition = 'opacity 0.14s ease';
    mainImg.addEventListener('touchstart', function (e) { swipeX = e.changedTouches[0].clientX; }, { passive: true });
    mainImg.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - swipeX;
      if (Math.abs(dx) > 44) setImage(dx < 0 ? currentIdx + 1 : currentIdx - 1);
    }, { passive: true });
  }

  /* ── VARIANT SELECTOR ── */
  var variantCards = document.querySelectorAll('.pcm-variant-card');
  var variantInput = document.getElementById('pcm-variant-id');
  var ctaInput     = document.getElementById('pcm-cta-variant-id');
  var mobileInput  = document.getElementById('pcm-mobile-variant-id');
  var confirmLabel = document.getElementById('pcm-confirm-label');

  function selectVariant(card) {
    variantCards.forEach(function (c) {
      c.classList.remove('selected');
      c.setAttribute('aria-checked', 'false');
      c.setAttribute('tabindex', '-1');
    });

    card.classList.add('selected');
    card.setAttribute('aria-checked', 'true');
    card.setAttribute('tabindex', '0');

    var vid  = card.dataset.variantId;
    var name = card.dataset.variantName;
    var col1 = card.dataset.color1;
    var col2 = card.dataset.color2;
    var img  = card.dataset.img;

    if (variantInput) variantInput.value = vid;
    if (ctaInput)     ctaInput.value     = vid;
    if (mobileInput)  mobileInput.value  = vid;

    if (confirmLabel) {
      confirmLabel.textContent = 'Selected: ' + name + ' \u2014 ' + col1 + ' + ' + col2;
    }

    if (img) setImage(0, img);

    try {
      var url = new URL(window.location.href);
      url.searchParams.set('variant', vid);
      window.history.replaceState({}, '', url.toString());
    } catch (e) {}
  }

  /* Initialise first checkmark visibility */
  var firstCheck = document.querySelector('.pcm-variant-card.selected .pcm-variant-check');
  if (firstCheck) { firstCheck.style.opacity = '1'; firstCheck.style.scale = '1'; }

  variantCards.forEach(function (card) {
    card.addEventListener('click', function () { selectVariant(card); });
    card.addEventListener('keydown', function (e) {
      var arr = Array.from(variantCards);
      var i   = arr.indexOf(card);
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault(); selectVariant(card);
      } else if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        e.preventDefault(); var n = arr[(i + 1) % arr.length]; selectVariant(n); n.focus();
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        e.preventDefault(); var p = arr[(i - 1 + arr.length) % arr.length]; selectVariant(p); p.focus();
      }
    });
  });

  /* ── STAT COUNTERS ── */
  document.querySelectorAll('.pcm-stat-count').forEach(function (el) {
    var target = parseInt(el.dataset.target, 10);
    var done   = false;
    var obs    = new IntersectionObserver(function (entries) {
      if (!entries[0].isIntersecting || done) return;
      done = true; obs.disconnect();
      var start = null;
      requestAnimationFrame(function tick(ts) {
        if (!start) start = ts;
        var p = Math.min((ts - start) / 1400, 1);
        el.textContent = Math.round((1 - Math.pow(1 - p, 3)) * target);
        if (p < 1) requestAnimationFrame(tick);
      });
    }, { threshold: 0.6 });
    obs.observe(el);
  });

  /* ── FAQ ACCORDION ── */
  document.querySelectorAll('.pcm-faq-q').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var open   = btn.getAttribute('aria-expanded') === 'true';
      var answer = btn.parentElement.querySelector('.pcm-faq-a');
      var icon   = btn.querySelector('.pcm-faq-icon');

      /* Close all others */
      document.querySelectorAll('.pcm-faq-q').forEach(function (other) {
        if (other === btn) return;
        other.setAttribute('aria-expanded', 'false');
        var a  = other.parentElement.querySelector('.pcm-faq-a');
        var ic = other.querySelector('.pcm-faq-icon');
        if (a) a.hidden = true;
        if (ic) ic.style.transform = 'rotate(0deg)';
      });

      if (!open) {
        btn.setAttribute('aria-expanded', 'true');
        if (answer) answer.hidden = false;
        if (icon) icon.style.transform = 'rotate(180deg)';
      } else {
        btn.setAttribute('aria-expanded', 'false');
        if (answer) answer.hidden = true;
        if (icon) icon.style.transform = 'rotate(0deg)';
      }
    });
  });

  /* ── STICKY MOBILE ATC BAR ── */
  var mobileBar = document.getElementById('pcm-mobile-bar');
  var mainAtc   = document.getElementById('pcm-main-atc');

  if (mobileBar && mainAtc) {
    var atcObserver = new IntersectionObserver(function (entries) {
      var visible = !entries[0].isIntersecting;
      mobileBar.classList.toggle('visible', visible);
      mobileBar.setAttribute('aria-hidden', visible ? 'false' : 'true');
    }, { threshold: 0.5 });
    atcObserver.observe(mainAtc);
  }

})();
</script>

