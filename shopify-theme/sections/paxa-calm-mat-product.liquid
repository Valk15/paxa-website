     MOTION.JS + PAGE SCRIPTS
════════════════════════════════════════════════════════════ -->
<script src="https://cdn.jsdelivr.net/npm/motion@latest/dist/motion.js"></script>
<script>
(function () {
  'use strict';

  /* ── STATE ── */
  var selectedVariantId   = '53536507068753';
  var selectedVariantName = 'The Protocol Pair';
  var selectedColor1      = 'Milk White';
  var selectedColor2      = 'Sky Blue';
  var currentImageIndex   = 0;

  var allImages = {{ product.images | map: 'src' | json }};

  /* ── MOTION ── */
  var M = (typeof Motion !== 'undefined') ? Motion : null;

  function mx(els, props, opts) {
    if (!M || !M.animate) return;
    try { M.animate(els, props, opts); } catch (e) {}
  }

  function mInView(sel, cb, opts) {
    if (!M || !M.inView) return;
    try {
      var els = typeof sel === 'string' ? document.querySelectorAll(sel) : [sel];
      els.forEach(function (el) { M.inView(el, cb, opts); });
    } catch (e) {}
  }

  /* ── A. HEADER ENTRANCE + SCROLL ── */
  var header = document.getElementById('pcm-header');
  if (header) {
    mx(header, { opacity: [0, 1], y: [-12, 0] }, { duration: 0.4, easing: 'easeOut' });
    window.addEventListener('scroll', function () {
      header.classList.toggle('pcm-header-scrolled', window.scrollY > 60);
    }, { passive: true });
  }

  /* ── B. HERO — headline word stagger ── */
  var words = document.querySelectorAll('#pcm-hero-headline .pcm-word');
  if (words.length && M) {
    mx(words, { opacity: [0, 1], y: [20, 0] }, {
      delay: M.stagger ? M.stagger(0.08) : 0,
      duration: 0.5,
      easing: [0.16, 1, 0.3, 1]
    });
  }

  /* Hero image entrance */
  var heroImg = document.querySelector('.pcm-hero-img');
  if (heroImg) {
    mx(heroImg, { scale: [1.05, 1], opacity: [0, 1] }, { duration: 0.9, easing: 'easeOut' });
  }

  /* ── SCROLL REVEAL (steps) ── */
  var reveals = document.querySelectorAll('.pcm-reveal');
  reveals.forEach(function (el) {
    mInView(el, function () {
      mx(el, { opacity: [0, 1], y: [28, 0] }, {
        duration: 0.6,
        easing: [0.16, 1, 0.3, 1]
      });
    }, { amount: 0.25 });
  });

  /* ── C. GALLERY ── */
  var mainImg  = document.getElementById('pcm-main-img');
  var thumbBtns = document.querySelectorAll('.pcm-thumb');
  var prevBtn  = document.getElementById('pcm-prev-btn');
  var nextBtn  = document.getElementById('pcm-next-btn');

  function setGalleryImage(index) {
    if (!mainImg || !allImages[index]) return;
    currentImageIndex = index;
    var src = allImages[index];

    if (M && M.animate) {
      M.animate(mainImg, { opacity: [1, 0] }, { duration: 0.15 });
      setTimeout(function () {
        mainImg.src = src;
        M.animate(mainImg, { opacity: [0, 1] }, { duration: 0.2 });
      }, 150);
    } else {
      mainImg.src = src;
    }

    thumbBtns.forEach(function (t) {
      var active = parseInt(t.dataset.index, 10) === index;
      t.classList.toggle('pcm-thumb-active', active);
      t.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
  }

  thumbBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      setGalleryImage(parseInt(btn.dataset.index, 10));
    });
  });

  if (prevBtn) prevBtn.addEventListener('click', function () {
    setGalleryImage((currentImageIndex - 1 + allImages.length) % allImages.length);
  });
  if (nextBtn) nextBtn.addEventListener('click', function () {
    setGalleryImage((currentImageIndex + 1) % allImages.length);
  });

  /* Touch swipe */
  var swipeStartX = 0;
  if (mainImg) {
    mainImg.addEventListener('touchstart', function (e) {
      swipeStartX = e.changedTouches[0].clientX;
    }, { passive: true });
    mainImg.addEventListener('touchend', function (e) {
      var dx = e.changedTouches[0].clientX - swipeStartX;
      if (Math.abs(dx) > 45) {
        setGalleryImage(dx < 0
          ? (currentImageIndex + 1) % allImages.length
          : (currentImageIndex - 1 + allImages.length) % allImages.length
        );
      }
    }, { passive: true });
  }

  /* ── C. VARIANT SELECTOR ── */
  var variantCards  = document.querySelectorAll('.pcm-variant-card');
  var selectedLabel = document.getElementById('pcm-selected-label');

  function selectVariant(card) {
    /* Deselect all */
    variantCards.forEach(function (c) {
      c.classList.remove('pcm-variant-selected');
      c.setAttribute('aria-checked', 'false');
      c.setAttribute('tabindex', '-1');
      var chk = c.querySelector('.pcm-variant-check');
      if (chk) {
        chk.style.scale = '0';
        if (M && M.animate) M.animate(chk, { scale: 0 }, { duration: 0.1 });
      }
    });

    /* Select this card */
    card.classList.add('pcm-variant-selected');
    card.setAttribute('aria-checked', 'true');
    card.setAttribute('tabindex', '0');

    var check = card.querySelector('.pcm-variant-check');
    if (check) {
      check.style.scale = '1';
      if (M && M.animate) {
        M.animate(check, { scale: [0, 1] }, {
          type: 'spring',
          stiffness: 500,
          damping: 25
        });
      }
    }

    /* Update global state */
    selectedVariantId   = card.dataset.variantId;
    selectedVariantName = card.dataset.variantName;
    selectedColor1      = card.dataset.color1Name;
    selectedColor2      = card.dataset.color2Name;

    /* Update confirmation label */
    if (selectedLabel) {
      selectedLabel.textContent = 'Selected: ' + selectedVariantName.replace('The ', '') + ' \u2014 ' + selectedColor1 + ' + ' + selectedColor2;
      if (M && M.animate) M.animate(selectedLabel, { opacity: [0, 1] }, { duration: 0.3 });
    }

    /* Reset gallery to first image */
    setGalleryImage(0);
  }

  variantCards.forEach(function (card) {
    card.addEventListener('click', function () { selectVariant(card); });
    card.addEventListener('keydown', function (e) {
      var arr = Array.from(variantCards);
      var idx = arr.indexOf(card);
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault(); selectVariant(card);
      } else if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        e.preventDefault(); var n = arr[(idx + 1) % arr.length]; selectVariant(n); n.focus();
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        e.preventDefault(); var p = arr[(idx - 1 + arr.length) % arr.length]; selectVariant(p); p.focus();
      }
    });
  });

  /* ── ATC HOVER / TAP ── */
  var atcBtn = document.getElementById('pcm-atc-btn');
  if (atcBtn && M && M.animate) {
    atcBtn.addEventListener('mouseenter', function () { M.animate(atcBtn, { y: -2 }, { duration: 0.15 }); });
    atcBtn.addEventListener('mouseleave', function () { M.animate(atcBtn, { y: 0  }, { duration: 0.15 }); });
    atcBtn.addEventListener('mousedown',  function () { M.animate(atcBtn, { scale: 0.97 }, { duration: 0.1 }); });
    atcBtn.addEventListener('mouseup',    function () { M.animate(atcBtn, { scale: 1    }, { duration: 0.1 }); });
  }

  /* ── CHECKOUT CONFIRMATION MODAL ── */
  var overlay    = document.getElementById('pcm-overlay');
  var pcmModal   = document.getElementById('pcm-modal');
  var confirmBtn = document.getElementById('pcm-confirm-btn');
  var cancelBtn  = document.getElementById('pcm-cancel-btn');
  var modalVariant = document.getElementById('pcm-modal-variant');
  var finalCTA   = document.getElementById('pcm-final-cta-btn');

  function openModal() {
    if (!overlay || !pcmModal) return;

    if (modalVariant) {
      modalVariant.textContent = selectedVariantName + ' \u2014 ' + selectedColor1 + ' + ' + selectedColor2;
    }
    if (confirmBtn) {
      confirmBtn.href = '/cart/' + selectedVariantId + ':1';
    }

    overlay.style.display = 'flex';
    overlay.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';

    if (M && M.animate) {
      M.animate(overlay, { opacity: [0, 1] }, { duration: 0.2 });
      M.animate(pcmModal, { opacity: [0, 1], y: [40, 0] }, {
        duration: 0.35,
        easing: 'easeOut'
      });
    }

    /* Focus management */
    setTimeout(function () { if (cancelBtn) cancelBtn.focus(); }, 100);
  }

  function closeModal() {
    if (!overlay) return;
    if (M && M.animate) {
      M.animate(overlay, { opacity: [1, 0] }, { duration: 0.15 });
      setTimeout(function () {
        overlay.style.display = 'none';
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }, 160);
    } else {
      overlay.style.display = 'none';
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    /* Return focus to trigger */
    if (atcBtn) atcBtn.focus();
  }

  if (atcBtn)   atcBtn.addEventListener('click', openModal);
  if (finalCTA) finalCTA.addEventListener('click', openModal);
  if (cancelBtn) cancelBtn.addEventListener('click', closeModal);

  if (overlay) {
    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) closeModal();
    });
  }

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && overlay && overlay.style.display === 'flex') closeModal();
  });

  /* ── D. STAT COUNTERS (IntersectionObserver) ── */
  var statEls = document.querySelectorAll('.pcm-stat-count');
  statEls.forEach(function (el) {
    var target  = parseInt(el.dataset.target, 10);
    var counted = false;
    var obs = new IntersectionObserver(function (entries) {
      if (!entries[0].isIntersecting || counted) return;
      counted = true;
      obs.disconnect();
      var start = null;
      var dur   = 1400;
      requestAnimationFrame(function tick(ts) {
        if (!start) start = ts;
        var p = Math.min((ts - start) / dur, 1);
        var ease = 1 - Math.pow(1 - p, 3); /* cubic ease-out */
        el.textContent = Math.round(ease * target);
        if (p < 1) requestAnimationFrame(tick);
      });
    }, { threshold: 0.6 });
    obs.observe(el);
  });

  /* ── F. FAQ ACCORDION ── */
  var faqBtns = document.querySelectorAll('.pcm-faq-question');
  faqBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var isOpen = btn.getAttribute('aria-expanded') === 'true';
      var answer = btn.parentElement.querySelector('.pcm-faq-answer');
      var icon   = btn.querySelector('.pcm-faq-icon');

      /* Close others */
      faqBtns.forEach(function (other) {
        if (other === btn) return;
        var otherAns  = other.parentElement.querySelector('.pcm-faq-answer');
        var otherIcon = other.querySelector('.pcm-faq-icon');
        other.setAttribute('aria-expanded', 'false');
        if (otherAns) otherAns.hidden = true;
        if (otherIcon && M && M.animate) M.animate(otherIcon, { rotate: 0 }, { duration: 0.22 });
      });

      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        if (answer) answer.hidden = false;
        if (icon && M && M.animate) M.animate(icon, { rotate: 180 }, { duration: 0.25, easing: 'easeInOut' });
      } else {
        btn.setAttribute('aria-expanded', 'false');
        if (answer) answer.hidden = true;
        if (icon && M && M.animate) M.animate(icon, { rotate: 0 }, { duration: 0.25, easing: 'easeInOut' });
      }
    });
  });

  /* ── INITIAL CHECKMARK STATE ── */
  var firstCard = document.querySelector('.pcm-variant-card.pcm-variant-selected .pcm-variant-check');
  if (firstCard) firstCard.style.scale = '1';

})();
</script>

